                    { text: "Encuentra el pronombre en: 'Ella descubrió una nueva estrella.'", display: "Pronombres", missing: "Ella", options: ["Ella", "descubrió", "nueva"], emoji: "👩‍🚀", hint: "Reemplaza al nombre propio de una persona." }
                ],
                science: [
                    { item: "El cuarto planeta desde el Sol, de color rojo", emoji: "🪐", display: "Marte", category: "Astronomía", options: ["Astronomía", "Biología Celular", "Geología Terrestre"], hint: "Llamado planeta rojo por los óxidos de su superficie." },
                    { item: "Un hongo descomponedor en un bosque húmedo", emoji: "🍄", display: "Fungi", category: "Reino Fungi", options: ["Reino Fungi", "Reino Plantae", "Reino Monera"], hint: "No hace fotosíntesis, se alimenta de materia en descomposición." },
                    { item: "Fuerza invisible que nos mantiene unidos al suelo", emoji: "🍎", display: "Gravedad", category: "Física", options: ["Física", "Astronomía", "Química"], hint: "Explicada por Isaac Newton tras observar una manzana caer." }
                ],
                civics: [
                    { text: "Un compañero comete un error en una presentación y todo el salón comienza a reírse. ¿Qué haces?", options: ["No me río y le doy apoyo visual con una sonrisa", "Me uno a la risa colectiva", "Le grito que se apure"], correct: 0, hint: "Detener la burla colectiva protege la autoestima de nuestro compañero." },
                    { text: "Hay un nuevo compañero de clase que viene de otro país y habla diferente. ¿Qué haces?", options: ["Lo integro al grupo y le pregunto sobre su cultura", "Me aparto porque habla raro", "Le digo que regrese a su país"], correct: 0, hint: "La diversidad cultural enriquece nuestra forma de ver el universo escolar." }
                ]
            },
            // GRADO 5 (Niños de 10-11 años - Operaciones formales iniciales)
            grade_5: {
                math: [
                    { termA: "0.5 + 0.75", termB: "", operator: '=', answer: "1.25", options: ["1.25", "1.20", "1.50"], hint: "Suma como centavos: 50 centavos más 75 centavos." },
                    { termA: "3/5 de 25", termB: "", operator: '=', answer: 15, options: [15, 10, 20], hint: "Divide 25 entre 5 y el resultado multiplícalo por 3." },
                    { termA: "12 + 4 × 3", termB: "", operator: '=', answer: 24, options: [24, 48, 36], hint: "Jerarquía de operaciones: la multiplicación se hace antes que la suma." }
                ],
                lang: [
                    { text: "En la palabra 'SUBMARINO', el fragmento 'SUB' es un...", display: "Prefijo", missing: "Prefijo", options: ["Prefijo", "Sufijo", "Lexema"], emoji: "🚢", hint: "Fragmento que se coloca antes de la raíz de la palabra." },
                    { text: "Identifica el adverbio de tiempo en: 'Mañana viajaremos al cometa Halley.'", display: "Adverbios", missing: "Mañana", options: ["Mañana", "Halley", "viajaremos"], emoji: "📅", hint: "Responde a la pregunta: ¿Cuándo ocurrirá la acción?" },
                    { text: "¿Cuál es el antónimo de la palabra 'EFÍMERO' (que dura muy poco)?", display: "EFÍMERO", missing: "Eterno", options: ["Eterno", "Pasajero", "Breve"], emoji: "⏳", hint: "Algo que no tiene final y dura para siempre." }
                ],
                science: [
                    { item: "La unidad básica y viva más pequeña de los seres", emoji: "🦠", display: "Célula", category: "Biología Celular", options: ["Biología Celular", "Astronomía", "Física de Partículas"], hint: "Puede ser eucariota o procariota, vegetal o animal." },
                    { item: "Energía obtenida mediante paneles solares espaciales", emoji: "☀️", display: "Energía Limpia", category: "Energía Renovable", options: ["Energía Renovable", "Combustible Fósil", "Energía Inerte"], hint: "Proviene de fuentes inagotables de la naturaleza." },
                    { item: "El sistema encargado de coordinar todas las funciones corporales", emoji: "🧠", display: "Sistema Nervioso", category: "Anatomía Humana", options: ["Anatomía Humana", "Sistema Circulatorio", "Aparato Excretor"], hint: "Usa neuronas para transmitir impulsos eléctricos veloces." }
                ],
                civics: [
                    { text: "En un grupo de chat del salón, un grupo de niños está enviando imágenes ofensivas de un compañero. ¿Qué haces?", options: ["Aviso a mis padres o maestros y apoyo al afectado", "Me río y reenvío las imágenes", "Me salgo del grupo sin decir nada"], correct: 0, hint: "El ciberacoso requiere una intervención activa de protección mutua." },
                    { text: "Tienes que hacer un trabajo difícil en grupo y un integrante propone ideas muy distintas a las tuyas. ¿Qué haces?", options: ["Escucho con respeto y buscamos fusionar las ideas", "Impongo mi idea porque es mejor", "Hago el trabajo solo para no discutir"], correct: 0, hint: "El liderazgo colectivo integra las visiones de todos los miembros." }
                ]
            }
        };

        const robotFeedbacks = {
            feliz: {
                correct: [
                    "🤖 ¡Estupendo, comandante! ¡Tu entusiasmo hoy nos hace acelerar la calibración!",
                    "🤖 ¡Respuesta óptima! Tus sistemas cognitivos están al 100% de rendimiento.",
                    "🤖 ¡Fabuloso! Tu energía positiva impulsa todo nuestro transbordador."
                ],
                incorrect: [
                    "🤖 ¡Casi! Reajustemos los sensores con calma e intentémoslo de nuevo.",
                    "🤖 ¡Uf, muy cerca! Tu radar detectará el canal correcto en el siguiente intento.",
                    "🤖 ¡Un pequeño bache espacial! Vamos a mirar la pista de soporte juntos."
                ]
            },
            cansado: {
                correct: [
                    "🤖 ¡Excelente! Un paso a la vez, tu perseverancia hoy brilla con fuerza.",
                    "🤖 ¡Muy bien hecho! Despacio pero seguro estamos recuperando los nodos.",
                    "🤖 ¡Excelente! Es normal estar agotado, pero tu mente sigue logrando grandes metas."
                ],
                incorrect: [
                    "🤖 No te presiones. Respira hondo, toma aire e inténtalo con calma de nuevo.",
                    "🤖 El cansancio es parte del viaje. Mira la pista espacial de Astrobot para ayudarte.",
                    "🤖 ¡Gran intento! Vamos sin prisa, sé que con la pista lo resolverás perfectamente."
                ]
            },
            curioso: {
                correct: [
                    "🤖 ¡Increíble deducción científica! Tu hipótesis ha sido completamente validada.",
                    "🤖 ¡Excelente análisis! Tu curiosidad está abriendo nuevos horizontes cognitivos.",
                    "🤖 ¡Excelente! Tu mente exploradora sigue descifrando las leyes del multiverso."
                ],
                incorrect: [
                    "🤖 ¡Una respuesta interesante! Pero los datos de la nave sugieren otra ruta. ¡Investiga de nuevo!",
                    "🤖 ¿Y si analizamos las variables otra vez? La pista guarda el misterio científico.",
                    "🤖 ¡Buen intento! La ciencia progresa intentándolo muchas veces. ¡Vamos de nuevo!"
                ]
            },
            nervioso: {
                correct: [
                    "🤖 ¡Lo lograste! Confía plenamente en tu gran talento, eres asombroso.",
                    "🤖 ¡Súper! Viste que no había nada que temer, tus sistemas están seguros.",
                    "🤖 ¡Maravilloso! Tu calma interior estabilizó los escudos con éxito."
                ],
                incorrect: [
                    "🤖 ¡Tranquilo, cadete! Aquí nadie pierde estrellas por intentar. Miremos la pista juntos.",
                    "🤖 Inhala... exhala... tu cabina protectora está segura. Intenta de nuevo a tu propio ritmo.",
                    "🤖 ¡No hay prisa! Astrobot te acompaña en cada paso. Revisemos el ejercicio con calma."
                ]
            }
        };

        function switchScreen(screenId) {
            document.getElementById("screen-welcome").classList.add("hidden");
            document.getElementById("screen-grade-select").classList.add("hidden");
            document.getElementById("screen-hub").classList.add("hidden");
            document.getElementById("screen-game").classList.add("hidden");
            document.getElementById("screen-workshop").classList.add("hidden");
            document.getElementById("screen-victory").classList.add("hidden");

            document.getElementById("screen-" + screenId).classList.remove("hidden");
        }

        function goHome() {
            switchScreen("hub");
        }

        // Selección de emoción inicial (Goleman)
        function selectEmotion(emotion) {
            state.selectedEmotion = emotion;
            
            const l = document.getElementById("bot-welcome-eye-l");
            const r = document.getElementById("bot-welcome-eye-r");
            
            // Retroalimentación visual empática instantánea en los ojos del droide
            if (emotion === 'feliz') { l.style.backgroundColor = "#34d399"; r.style.backgroundColor = "#34d399"; }
            else if (emotion === 'cansado') { l.style.backgroundColor = "#38bdf8"; r.style.backgroundColor = "#38bdf8"; }
            else if (emotion === 'curioso') { l.style.backgroundColor = "#fbbf24"; r.style.backgroundColor = "#fbbf24"; }
            else { l.style.backgroundColor = "#c084fc"; r.style.backgroundColor = "#c084fc"; }

            playSynth(523.25, "sine", 0.35);

            setTimeout(() => {
                // Configurar los ojos de la cabina de juego del Astrobot
                const el = document.getElementById("bot-eye-l");
                const er = document.getElementById("bot-eye-r");
                el.style.backgroundColor = l.style.backgroundColor;
                er.style.backgroundColor = r.style.backgroundColor;

                // Saludo adaptado
                document.getElementById("astrobot-bubble").innerText = robotFeedbacks[emotion].correct[0];

                // Transición al selector de grado
                switchScreen("grade-select");
            }, 800);
        }

        // Selección de grado escolar (Piaget)
        function selectGrade(grade) {
            state.selectedGrade = grade;
            playSynth(659.25, "sine", 0.3);
            
            // Actualizar etiquetas visuales de grado en la cabina
            document.getElementById("player-grade-label").innerText = grade + "º Primaria";
            
            switchScreen("hub");
        }

        // Actualizar estadísticas globales
        function updateGlobalStats() {
            document.getElementById("global-stars").innerText = state.stars;
        }

        // Inicio de materia
        function startSubject(subject) {
            state.currentSubject = subject;
            state.currentPhase = 1;
            state.missionProgress = 0;

            const icon = document.getElementById("game-subject-icon");
            const board = document.getElementById("tactical-board");

            // Configuración estética y visual por planeta/materia
            if (subject === 'math') {
                icon.className = "fa-solid fa-cubes-stacked text-rose-400";
                board.className = "lg:col-span-3 bg-slate-950/85 rounded-2xl border flex flex-col justify-between p-5 relative overflow-hidden min-h-[350px] neon-glow-math";
                document.getElementById("game-subject-title").innerText = "Planeta Aritmética";
            } else if (subject === 'lang') {
                icon.className = "fa-solid fa-book-open-reader text-cyan-400";
                board.className = "lg:col-span-3 bg-slate-950/85 rounded-2xl border flex flex-col justify-between p-5 relative overflow-hidden min-h-[350px] neon-glow-lang";
                document.getElementById("game-subject-title").innerText = "Valle Sintaxis";
            } else if (subject === 'science') {
                icon.className = "fa-solid fa-seedling text-emerald-400";
                board.className = "lg:col-span-3 bg-slate-950/85 rounded-2xl border flex flex-col justify-between p-5 relative overflow-hidden min-h-[350px] neon-glow-science";
                document.getElementById("game-subject-title").innerText = "Planeta Biosistema";
            } else {
                icon.className = "fa-solid fa-handshake-angle text-purple-400";
                board.className = "lg:col-span-3 bg-slate-950/85 rounded-2xl border flex flex-col justify-between p-5 relative overflow-hidden min-h-[350px] neon-glow-civics";
                document.getElementById("game-subject-title").innerText = "Oasis Convivencia";
            }

            updateProgressBar();
            generateChallenge();
            switchScreen("game");
        }

        function updateProgressBar() {
            document.getElementById("game-level-display").innerText = "Fase " + state.currentPhase;
            document.getElementById("mission-progress-text").innerText = state.missionProgress + "%";
            document.getElementById("mission-progress-bar").style.width = state.missionProgress + "%";

            if (state.missionProgress >= 100) {
                setTimeout(triggerVictory, 800);
            }
        }

        function triggerVictory() {
            state.stars += 5;
            updateGlobalStats();
            document.getElementById("victory-title").innerText = "¡Misión de Grado " + state.selectedGrade + " Lograda!";
            
            let finishMsg = "";
            if (state.currentSubject === 'math') finishMsg = "🤖 ¡Asombroso comandante! Calibraste todos los nodos numéricos del grado " + state.selectedGrade + " usando lógica estelar.";
            if (state.currentSubject === 'lang') finishMsg = "🤖 ¡Excelente! El código lingüístico y sintáctico ha sido estabilizado para guiar nuestra órbita.";
            if (state.currentSubject === 'science') finishMsg = "🤖 ¡Fabuloso! Tu análisis ecosistémico y biológico aportará un valioso saber a la base central.";
            if (state.currentSubject === 'civics') finishMsg = "🤖 ¡Maravilloso! El diálogo, el civismo y la empatía son las fuerzas más poderosas del cosmos.";

            document.getElementById("victory-text").innerText = finishMsg;
            switchScreen("victory");
            playSynth(880, "sine", 0.5);
        }

        function generateChallenge() {
            // Ocultar todos los contenedores específicos de retos
            document.getElementById("game-math-container").classList.add("hidden");
            document.getElementById("game-lang-container").classList.add("hidden");
            document.getElementById("game-science-container").classList.add("hidden");
            document.getElementById("game-civics-container").classList.add("hidden");

            // Restablecer color de los ojos de Astrobot según emoción
            selectEmotionEyes(state.selectedEmotion);

            // Cargar el banco correspondiente al grado escolar y materia activa
            const gradeKey = "grade_" + state.selectedGrade;
            const subjectKey = state.currentSubject;
            const database = CHALLENGE_DATABASE[gradeKey][subjectKey];
            
            // Selección aleatoria del reto
            const challenge = database[Math.floor(Math.random() * database.length)];
            state.currentChallengeData = challenge;

            if (subjectKey === 'math') {
                buildMathChallenge(challenge);
            } else if (subjectKey === 'lang') {
                buildLanguageChallenge(challenge);
            } else if (subjectKey === 'science') {
                buildScienceChallenge(challenge);
            } else if (subjectKey === 'civics') {
                buildCivicsChallenge(challenge);
            }
        }

        function buildMathChallenge(data) {
            document.getElementById("game-math-container").classList.remove("hidden");
            document.getElementById("tactical-question").innerText = "🤖 ¡Resuelve el enigma numérico del Grado " + state.selectedGrade + "!";
            document.getElementById("tactical-hint").innerText = "Matemáticas en Desarrollo Lógico";

            document.getElementById("math-term-a").innerText = data.termA;
            document.getElementById("math-operator").innerText = data.operator;
            document.getElementById("math-term-b").innerText = data.termB;

            const concreteWrapper = document.getElementById("math-concrete-wrapper");
            
            // Los bloques multibase de Piaget solo se renderizan para Grados 1 y 2 para no sobrecargar el pensamiento abstracto en Grados 3, 4 y 5
            if (state.selectedGrade <= 2 && typeof data.termA === 'number' && typeof data.termB === 'number') {
                concreteWrapper.classList.remove("hidden");
                const containerA = document.getElementById("math-visual-a");
                const containerB = document.getElementById("math-visual-b");
                const visualOp = document.getElementById("math-visual-op");

                containerA.innerHTML = "";
                containerB.innerHTML = "";
                visualOp.innerText = data.operator;

                renderBlocks(data.termA, containerA);
                renderBlocks(data.termB, containerB);
            } else {
                concreteWrapper.classList.add("hidden");
            }

            setupOptions(data.answer, data.options);
        }

        // Función para renderizar cubos de unidades (azul) y decenas (naranja)
        function renderBlocks(value, container) {
            const tens = Math.floor(value / 10);
            const ones = value % 10;

            // Decenas
            for (let t = 0; t < tens; t++) {
                container.innerHTML += `
                    <div class="w-3.5 h-10 bg-amber-500 rounded border border-amber-300 flex flex-col justify-between p-0.5 shadow-sm" title="Decena (10)">
                        <div class="h-1 bg-amber-600 rounded-sm"></div>
                        <div class="h-1 bg-amber-600 rounded-sm"></div>
                        <div class="h-1 bg-amber-600 rounded-sm"></div>
                        <div class="h-1 bg-amber-600 rounded-sm"></div>
                    </div>`;
            }
            // Unidades
            for (let o = 0; o < ones; o++) {
                container.innerHTML += `
                    <div class="w-3.5 h-3.5 bg-cyan-500 rounded border border-cyan-300 shadow-sm" title="Unidad (1)"></div>
                `;
            }
        }

        // Retos de lenguaje
        function buildLanguageChallenge(data) {
            document.getElementById("game-lang-container").classList.remove("hidden");
            document.getElementById("tactical-question").innerText = "🤖 " + data.text;
            document.getElementById("tactical-hint").innerText = "Dimensión Lingüística-Comunicativa";

            document.getElementById("lang-visual-emoji").innerText = data.emoji;
            document.getElementById("lang-word-display").innerText = data.display;
            document.getElementById("lang-word-hint").innerText = `"${data.text}"`;

            setupOptions(data.missing, data.options);
        }

        // Retos de ciencia
        function buildScienceChallenge(data) {
            document.getElementById("game-science-container").classList.remove("hidden");
            document.getElementById("tactical-question").innerText = "🤖 Estudiando: " + data.item;
            document.getElementById("tactical-hint").innerText = "Análisis Científico de la Nave";

            document.getElementById("science-item-display").innerText = data.emoji;
            document.getElementById("science-item-name").innerText = data.display;

            setupOptions(data.category, data.options);
        }

        // Retos de convivencia (Habilidades blandas)
        function buildCivicsChallenge(data) {
            document.getElementById("game-civics-container").classList.remove("hidden");
            document.getElementById("tactical-question").innerText = "🤖 Dilema Socioemocional";
            document.getElementById("tactical-hint").innerText = "Habilidades Blandas e Inclusión";

            document.getElementById("civics-scenario-text").innerText = `"${data.text}"`;

            setupOptions(data.options[data.correct], data.options);
        }

        // Preparar opciones de respuesta mutile y mezclarlas
        function setupOptions(correctVal, rawOptions) {
            const opts = [...rawOptions];
            if (!opts.includes(correctVal)) {
                opts[0] = correctVal;
            }
            opts.sort(() => Math.random() - 0.5);

            state.correctAnswerIndex = opts.indexOf(correctVal);

            for (let i = 0; i < 3; i++) {
                document.getElementById("answer-" + i).innerText = opts[i];
            }
        }

        // Soporte mediado: Pistas (Vygotsky - Andamiaje)
        function activateHint() {
            if (state.currentChallengeData && state.currentChallengeData.hint) {
                const bubble = document.getElementById("astrobot-bubble");
                bubble.innerText = "🤖 Pista de Astrobot: " + state.currentChallengeData.hint;
                playSynth(700, "triangle", 0.35);

                const el = document.getElementById("bot-eye-l");
                const er = document.getElementById("bot-eye-r");
                el.style.backgroundColor = "#fbbf24";
                er.style.backgroundColor = "#fbbf24";
            }
        }

        function checkAnswer(index) {
            const bubble = document.getElementById("astrobot-bubble");
            const emotionalState = state.selectedEmotion;

            if (index === state.correctAnswerIndex) {
                // Éxito: Refuerzo positivo
                playCorrectSound();
                setBotEyesColor("#34d399"); // Ojos verdes de felicidad

                const msg = robotFeedbacks[emotionalState].correct[Math.floor(Math.random() * robotFeedbacks[emotionalState].correct.length)];
                bubble.innerText = msg;

                state.stars += 2;
                state.missionProgress = Math.min(100, state.missionProgress + 25);
                updateGlobalStats();
                updateProgressBar();

                if (state.missionProgress < 100) {
                    state.currentPhase += 1;
                    setTimeout(generateChallenge, 1800);
                }
            } else {
                // Error constructivo: No penalización trágica (Ética del cuidado)
                playIncorrectSound();
                setBotEyesColor("#f59e0b"); // Ojos amarillos reflexivos

                const msg = robotFeedbacks[emotionalState].incorrect[Math.floor(Math.random() * robotFeedbacks[emotionalState].incorrect.length)];
                bubble.innerText = msg;

                // Animación suave del panel para centrar atención visual
                const board = document.getElementById("tactical-board");
                board.classList.add("translate-x-1");
                setTimeout(() => board.classList.remove("translate-x-1"), 80);
            }
        }

        function setBotEyesColor(hexColor) {
            document.getElementById("bot-eye-l").style.backgroundColor = hexColor;
            document.getElementById("bot-eye-r").style.backgroundColor = hexColor;
        }

        function selectEmotionEyes(emotion) {
            if (emotion === 'feliz') setBotEyesColor("#34d399");
            else if (emotion === 'cansado') setBotEyesColor("#38bdf8");
            else if (emotion === 'curioso') setBotEyesColor("#fbbf24");
            else setBotEyesColor("#c084fc");
        }

        function buyCosmetic(color, cost) {
            const bubble = document.getElementById("astrobot-bubble");
            if (state.stars >= cost) {
                state.stars -= cost;
                state.cosmetics[color].bought = true;
                state.cosmetics[color].active = true;

                updateGlobalStats();
                playPurchaseSound();

                const btn = document.getElementById("buy-" + color);
                btn.className = "bg-emerald-600 text-white font-bold text-[10px] px-2.5 py-1.5 rounded-lg flex items-center gap-1 cursor-default";
                btn.innerHTML = `<i class="fa-solid fa-circle-check"></i> Activo`;
                btn.disabled = true;

                const body = document.getElementById("custom-ship-body");
                body.className.baseVal = `ship-part-${color} transition-all duration-300`;
                
                document.getElementById("custom-ship-status").innerText = "Fuselaje " + color.toUpperCase() + " Acoplado";
            } else {
                playIncorrectSound();
                // Advertencia no intrusiva de Astrobot
                bubble.innerText = "🤖 ¡Oh cadete! Aún nos faltan algunas Monedas de Sabiduría en nuestro cofre para poder forjar este fuselaje. ¡Sigue estabilizando planetas!";
            }
        }

        // Inicio por defecto de la aplicación en ventana de carga
        window.onload = function() {
            updateGlobalStats();
        }
    </script>
</body>
</html>