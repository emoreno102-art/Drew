<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CosmoAcademia: Multiverso del Saber</title>
    <!-- Tailwind CSS para diseño moderno, dinámico y responsivo -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Fuentes amigables y legibles para transiciones de 6 a 11 años -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Comfortaa:wght@500;700&family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap" rel="stylesheet">
    <!-- Iconografía fluida de Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #050414;
            color: #f8fafc;
            overflow-x: hidden;
        }
        h1, h2, h3, .font-kid {
            font-family: 'Comfortaa', cursive;
        }
        
        /* Fondo activo: Nebulosa espacial dinámica */
        .cosmic-nebula {
            background: radial-gradient(circle at 50% 50%, #150d33 0%, #04030d 100%);
            position: relative;
        }

        .stars-canvas {
            background-image: 
                radial-gradient(white, rgba(255,255,255,.15) 1px, transparent 35px),
                radial-gradient(white, rgba(255,255,255,.1) 1.5px, transparent 25px);
            background-size: 350px 350px, 250px 250px;
            animation: moveStars 160s linear infinite;
        }

        @keyframes moveStars {
            from { background-position: 0 0, 15px 30px; }
            to { background-position: 350px 700px, 265px 730px; }
        }

        /* Flotación suave para Astrobot (Vygotsky / Goleman) */
        .droid-float {
            animation: floatDroid 5s ease-in-out infinite;
        }
        @keyframes floatDroid {
            0%, 100% { transform: translateY(0px) rotate(0deg); }
            50% { transform: translateY(-10px) rotate(1.5deg); }
        }

        /* Efectos de neón adaptativos por planeta escolar */
        .neon-glow-math { box-shadow: 0 0 25px rgba(244, 63, 94, 0.45); border-color: #f43f5e; }
        .neon-glow-lang { box-shadow: 0 0 25px rgba(56, 189, 248, 0.45); border-color: #38bdf8; }
        .neon-glow-science { box-shadow: 0 0 25px rgba(52, 211, 153, 0.45); border-color: #34d399; }
        .neon-glow-civics { box-shadow: 0 0 25px rgba(168, 85, 247, 0.45); border-color: #a855f7; }

        /* Clases del fuselaje del taller */
        .ship-part-default { fill: #0ea5e9; }
        .ship-part-rose { fill: #f43f5e; }
        .ship-part-emerald { fill: #10b981; }
        .ship-part-gold { fill: #eab308; }
    </style>
</head>
<body class="min-h-screen flex flex-col justify-between cosmic-nebula select-none">
    <div class="stars-canvas absolute inset-0 z-0 pointer-events-none"></div>

    <!-- CABECERA DE LA NAVEGACIÓN GLOBAL -->
    <header class="relative z-10 w-full max-w-6xl mx-auto px-4 py-3 flex justify-between items-center border-b border-indigo-950/40 bg-slate-950/45 backdrop-blur-md rounded-b-3xl">
        <div class="flex items-center gap-3 cursor-pointer" onclick="goHome()">
            <div class="bg-gradient-to-tr from-indigo-900 to-purple-950 p-2.5 rounded-2xl border border-indigo-500/30 flex items-center justify-center">
                <i class="fa-solid fa-user-astronaut text-cyan-400 text-xl animate-pulse"></i>
            </div>
            <div>
                <h1 class="text-sm md:text-lg font-bold tracking-wide text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 via-pink-400 to-purple-400">CosmoAcademia</h1>
                <p class="text-[10px] md:text-xs text-slate-400">Multiverso Escolar de Sabiduría</p>
            </div>
        </div>

        <div class="flex items-center gap-2 md:gap-3">
            <!-- Insignia del Curso Seleccionado -->
            <div class="bg-indigo-950/80 px-3 py-1.5 rounded-xl border border-indigo-500/30 text-xs flex items-center gap-1.5">
                <i class="fa-solid fa-graduation-cap text-purple-400"></i>
                <span id="player-grade-label" class="font-semibold text-slate-200">1º Primaria</span>
            </div>

            <!-- Monedas Cósmicas (Economía de fichas) -->
            <div class="bg-slate-950/90 border border-amber-500/30 rounded-xl py-1.5 px-3 flex items-center gap-2 shadow-[0_0_15px_rgba(245,158,11,0.15)]">
                <i class="fa-solid fa-circle-nodes text-amber-400 animate-spin" style="animation-duration: 12s;"></i>
                <span id="global-stars" class="font-bold text-amber-300 font-kid text-sm md:text-base">0</span>
            </div>

            <!-- Botón del Hangar -->
            <button onclick="switchScreen('workshop')" class="bg-gradient-to-r from-purple-600 to-indigo-600 hover:from-purple-500 hover:to-indigo-500 active:scale-95 transition-all px-3 py-2 rounded-xl text-xs font-semibold flex items-center gap-1.5 border border-purple-400/25 shadow-md">
                <i class="fa-solid fa-rocket"></i> <span class="hidden sm:inline">Hangar</span>
            </button>

            <!-- Control de Audio -->
            <button onclick="toggleAudio()" class="text-slate-400 hover:text-white transition-colors p-2 text-base md:text-lg">
                <i id="audio-icon" class="fa-solid fa-volume-xmark"></i>
            </button>
        </div>
    </header>

    <!-- PANTALLA 1: CONTROL EMOCIONAL / BIENVENIDA (Daniel Goleman) -->
    <main id="screen-welcome" class="relative z-10 flex-grow flex flex-col items-center justify-center text-center px-4 max-w-4xl mx-auto w-full py-6">
        <div class="mb-4 droid-float flex flex-col items-center">
            <!-- Droide de Apoyo Psicológico -->
            <div class="bg-gradient-to-b from-indigo-500 to-indigo-700 w-20 h-16 rounded-3xl border-3 border-slate-950 shadow-xl relative flex items-center justify-center">
                <div class="w-16 h-11 bg-slate-950 rounded-2xl flex items-center justify-around px-2 border border-indigo-400">
                    <div class="w-3 h-3 bg-cyan-400 rounded-full animate-pulse" id="bot-welcome-eye-l"></div>
                    <div class="w-3 h-3 bg-cyan-400 rounded-full animate-pulse" id="bot-welcome-eye-r"></div>
                </div>
                <div class="absolute -top-4 w-0.5 h-4 bg-indigo-400">
                    <div class="absolute -top-2 -left-1.5 w-4 h-4 bg-yellow-400 rounded-full animate-bounce"></div>
                </div>
            </div>
            <div class="w-8 h-3 bg-slate-800 rounded-b-xl border-t border-indigo-300 relative">
                <div class="absolute left-2.5 -bottom-1.5 w-3 h-3 bg-orange-500 rounded-full animate-ping"></div>
            </div>
        </div>

        <div class="bg-slate-950/70 border border-indigo-500/20 rounded-3xl p-5 md:p-6 max-w-2xl mb-6 backdrop-blur-md">
            <h2 class="text-xl md:text-2xl font-bold text-slate-100 mb-2 font-kid">¡Bienvenidos al Multiverso!</h2>
            <p class="text-xs md:text-sm text-indigo-200">
                🤖 "Hola Cadete, soy Astrobot. Antes de iniciar la calibración de nuestros propulsores... <strong>¿Cómo te sientes hoy?</strong> Tu estado emocional equilibra nuestros escudos de navegación."
            </p>
        </div>

        <!-- Mapeo de Emociones -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3 w-full max-w-2xl mb-8">
            <button onclick="selectEmotion('feliz')" class="group p-4 bg-emerald-950/30 hover:bg-emerald-900/40 border border-emerald-500/20 hover:border-emerald-400 rounded-2xl transition-all active:scale-95 flex flex-col items-center gap-2">
                <span class="text-3xl">🌟</span>
                <span class="font-bold text-xs text-emerald-300 font-kid">Alegre / Enérgico</span>
            </button>
            <button onclick="selectEmotion('cansado')" class="group p-4 bg-blue-950/30 hover:bg-blue-900/40 border border-blue-500/20 hover:border-blue-400 rounded-2xl transition-all active:scale-95 flex flex-col items-center gap-2">
                <span class="text-3xl">💤</span>
                <span class="font-bold text-xs text-blue-300 font-kid">Un Poco Cansado</span>
            </button>
            <button onclick="selectEmotion('curioso')" class="group p-4 bg-amber-950/30 hover:bg-amber-900/40 border border-amber-500/20 hover:border-amber-400 rounded-2xl transition-all active:scale-95 flex flex-col items-center gap-2">
                <span class="text-3xl">🤔</span>
                <span class="font-bold text-xs text-amber-300 font-kid">Muy Curioso</span>
            </button>
            <button onclick="selectEmotion('nervioso')" class="group p-4 bg-purple-950/30 hover:bg-purple-900/40 border border-purple-500/20 hover:border-purple-400 rounded-2xl transition-all active:scale-95 flex flex-col items-center gap-2">
                <span class="text-3xl">🛸</span>
                <span class="font-bold text-xs text-purple-300 font-kid">Algo Impaciente</span>
            </button>
        </div>
    </main>

    <!-- PANTALLA 1.5: SELECCIÓN DE GRADO (Adaptación Piagetiana) -->
    <main id="screen-grade-select" class="hidden relative z-10 flex-grow flex flex-col items-center justify-center text-center px-4 max-w-4xl mx-auto w-full py-6">
        <h2 class="text-2xl md:text-3xl font-bold text-slate-100 mb-2 font-kid">Calibra tu Nivel Escolar</h2>
        <p class="text-xs md:text-sm text-slate-400 mb-6">Cada nivel configura misiones alineadas con las etapas de desarrollo cognitivo.</p>

        <div class="grid grid-cols-1 sm:grid-cols-5 gap-4 w-full max-w-4xl">
            <!-- 1º de Primaria -->
            <button onclick="selectGrade(1)" class="p-5 bg-slate-950/80 hover:bg-slate-900 border border-slate-800 hover:border-cyan-500 rounded-2xl transition-all flex flex-col items-center justify-between text-center group active:scale-95">
                <div class="text-3xl text-cyan-400 mb-2 group-hover:scale-110 transition-transform"><i class="fa-solid fa-cubes"></i></div>
                <h3 class="font-bold text-sm text-white font-kid">1º Grado</h3>
                <p class="text-[10px] text-slate-500 mt-1">Conteo, sílabas y seres vivos.</p>
            </button>

            <!-- 2º de Primaria -->
            <button onclick="selectGrade(2)" class="p-5 bg-slate-950/80 hover:bg-slate-900 border border-slate-800 hover:border-purple-500 rounded-2xl transition-all flex flex-col items-center justify-between text-center group active:scale-95">
                <div class="text-3xl text-purple-400 mb-2 group-hover:scale-110 transition-transform"><i class="fa-solid fa-pencil"></i></div>
                <h3 class="font-bold text-sm text-white font-kid">2º Grado</h3>
                <p class="text-[10px] text-slate-500 mt-1">Sumas llevando, ortografía y estados físicos.</p>
            </button>

            <!-- 3º de Primaria -->
            <button onclick="selectGrade(3)" class="p-5 bg-slate-950/80 hover:bg-slate-900 border border-slate-800 hover:border-rose-500 rounded-2xl transition-all flex flex-col items-center justify-between text-center group active:scale-95">
                <div class="text-3xl text-rose-400 mb-2 group-hover:scale-110 transition-transform"><i class="fa-solid fa-calculator"></i></div>
                <h3 class="font-bold text-sm text-white font-kid">3º Grado</h3>
                <p class="text-[10px] text-slate-500 mt-1">Multiplicaciones, acentos y ecosistemas.</p>
            </button>

            <!-- 4º de Primaria -->
            <button onclick="selectGrade(4)" class="p-5 bg-slate-950/80 hover:bg-slate-900 border border-slate-800 hover:border-emerald-500 rounded-2xl transition-all flex flex-col items-center justify-between text-center group active:scale-95">
                <div class="text-3xl text-emerald-400 mb-2 group-hover:scale-110 transition-transform"><i class="fa-solid fa-dna"></i></div>
                <h3 class="font-bold text-sm text-white font-kid">4º Grado</h3>
                <p class="text-[10px] text-slate-500 mt-1">Fracciones, oraciones y sistema solar.</p>
            </button>

            <!-- 5º de Primaria -->
            <button onclick="selectGrade(5)" class="p-5 bg-slate-950/80 hover:bg-slate-900 border border-slate-800 hover:border-amber-500 rounded-2xl transition-all flex flex-col items-center justify-between text-center group active:scale-95">
                <div class="text-3xl text-amber-400 mb-2 group-hover:scale-110 transition-transform"><i class="fa-solid fa-brain"></i></div>
                <h3 class="font-bold text-sm text-white font-kid">5º Grado</h3>
                <p class="text-[10px] text-slate-500 mt-1">Decimales, gramática avanzada y ciudadanía digital.</p>
            </button>
        </div>
    </main>

    <!-- PANTALLA 2: MAPA DEL COSMOS / HUB SELECCIÓN PLANETAS -->
    <main id="screen-hub" class="hidden relative z-10 flex-grow flex flex-col items-center justify-center px-4 max-w-6xl mx-auto w-full py-6">
        <div class="text-center mb-6 max-w-2xl">
            <h2 class="text-xl md:text-3xl font-bold text-slate-100 mb-1 font-kid">Sistemas Orbitantes de Aprendizaje</h2>
            <p class="text-xs text-indigo-300">Navega libremente hacia el planeta que desees estabilizar con tu conocimiento.</p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 w-full">
            <!-- MATEMÁTICAS (Operaciones lógicas y concreción) -->
            <div onclick="startSubject('math')" class="group cursor-pointer bg-slate-950/70 hover:bg-slate-950/90 transition-all p-5 rounded-3xl border border-slate-800 hover:border-rose-500 flex flex-col justify-between text-center relative overflow-hidden h-[240px]">
                <div class="absolute -top-8 -right-8 w-20 h-20 bg-rose-500/5 rounded-full blur-xl"></div>
                <div class="text-4xl text-rose-500 mb-1"><i class="fa-solid fa-cubes-stacked"></i></div>
                <div>
                    <h3 class="text-base font-bold text-rose-400 mb-1 font-kid">Planeta Aritmética</h3>
                    <p class="text-[11px] text-slate-400 leading-relaxed">Cálculos, bloques lógicos y números estelares adaptados.</p>
                </div>
                <span class="inline-block bg-rose-500/10 text-rose-300 text-[10px] px-3 py-1 rounded-xl font-semibold uppercase group-hover:bg-rose-500 group-hover:text-white transition-all">Estabilizar</span>
            </div>

            <!-- LENGUAJE (Comunicación, estructura y dialógica) -->
            <div onclick="startSubject('lang')" class="group cursor-pointer bg-slate-950/70 hover:bg-slate-950/90 transition-all p-5 rounded-3xl border border-slate-800 hover:border-cyan-500 flex flex-col justify-between text-center relative overflow-hidden h-[240px]">
                <div class="absolute -top-8 -right-8 w-20 h-20 bg-cyan-500/5 rounded-full blur-xl"></div>
                <div class="text-4xl text-cyan-400 mb-1"><i class="fa-solid fa-book-open-reader"></i></div>
                <div>
                    <h3 class="text-base font-bold text-cyan-300 mb-1 font-kid">Valle de la Sintaxis</h3>
                    <p class="text-[11px] text-slate-400 leading-relaxed">Ortografía interactiva, comprensión de textos y sintaxis espacial.</p>
                </div>
                <span class="inline-block bg-cyan-500/10 text-cyan-300 text-[10px] px-3 py-1 rounded-xl font-semibold uppercase group-hover:bg-cyan-500 group-hover:text-white transition-all">Explorar</span>
            </div>

            <!-- CIENCIAS (Montessori sensorial, medio ambiente, el cuidado) -->
            <div onclick="startSubject('science')" class="group cursor-pointer bg-slate-950/70 hover:bg-slate-950/90 transition-all p-5 rounded-3xl border border-slate-800 hover:border-emerald-500 flex flex-col justify-between text-center relative overflow-hidden h-[240px]">
                <div class="absolute -top-8 -right-8 w-20 h-20 bg-emerald-500/5 rounded-full blur-xl"></div>
                <div class="text-4xl text-emerald-400 mb-1"><i class="fa-solid fa-seedling"></i></div>
                <div>
                    <h3 class="text-base font-bold text-emerald-300 mb-1 font-kid">Planeta Biosistema</h3>
                    <p class="text-[11px] text-slate-400 leading-relaxed">Ecología, la vida humana, materia, física y reinos naturales.</p>
                </div>
                <span class="inline-block bg-emerald-500/10 text-emerald-300 text-[10px] px-3 py-1 rounded-xl font-semibold uppercase group-hover:bg-emerald-500 group-hover:text-white transition-all">Analizar</span>
            </div>

            <!-- VALORES Y HABILIDADES SOCIOEMOCIONALES -->
            <div onclick="startSubject('civics')" class="group cursor-pointer bg-slate-950/70 hover:bg-slate-950/90 transition-all p-5 rounded-3xl border border-slate-800 hover:border-purple-500 flex flex-col justify-between text-center relative overflow-hidden h-[240px]">
                <div class="absolute -top-8 -right-8 w-20 h-20 bg-purple-500/5 rounded-full blur-xl"></div>
                <div class="text-4xl text-purple-400 mb-1"><i class="fa-solid fa-handshake-angle"></i></div>
                <div>
                    <h3 class="text-base font-bold text-purple-300 mb-1 font-kid">Oasis Convivencia</h3>
                    <p class="text-[11px] text-slate-400 leading-relaxed">Habilidades blandas, empatía en el aula, tolerancia y ciudadanía digital.</p>
                </div>
                <span class="inline-block bg-purple-500/10 text-purple-300 text-[10px] px-3 py-1 rounded-xl font-semibold uppercase group-hover:bg-purple-500 group-hover:text-white transition-all">Convivir</span>
            </div>
        </div>

        <button onclick="switchScreen('grade-select')" class="mt-8 bg-slate-900 hover:bg-slate-850 px-4 py-2 border border-slate-800 hover:border-slate-700 text-xs text-slate-300 rounded-xl transition-all">
            <i class="fa-solid fa-arrows-rotate mr-1"></i> Cambiar de Grado Académico
        </button>
    </main>

    <!-- PANTALLA 3: CABINA DEL RETO ACTIVO -->
    <main id="screen-game" class="hidden relative z-10 flex-grow flex flex-col items-center justify-between max-w-6xl mx-auto w-full px-4 py-4">
        <!-- Barra superior del reto en curso -->
        <div class="w-full grid grid-cols-1 md:grid-cols-3 items-center gap-4 bg-slate-950/90 border border-slate-900 p-4 rounded-2xl mb-4 shadow-xl">
            <div class="text-left">
                <span id="game-subject-title" class="text-[10px] text-slate-400 uppercase tracking-widest font-semibold">Materia Estelar</span>
                <div class="flex items-center gap-2 mt-0.5">
                    <i id="game-subject-icon" class="fa-solid fa-calculator text-rose-400"></i>
                    <span id="game-level-display" class="font-kid font-bold text-slate-200 text-sm">Cargando fase...</span>
                </div>
            </div>
            
            <div class="flex flex-col items-center">
                <div class="flex justify-between w-full text-[10px] text-slate-400 px-1 mb-1">
                    <span>Estabilización del Nodo</span>
                    <span id="mission-progress-text" class="text-amber-400 font-bold">0%</span>
                </div>
                <div class="w-full bg-slate-900 h-2.5 rounded-full overflow-hidden border border-slate-800 p-0.5">
                    <div id="mission-progress-bar" class="bg-gradient-to-r from-cyan-500 via-emerald-400 to-amber-400 h-full rounded-full transition-all duration-500" style="width: 0%;"></div>
                </div>
            </div>

            <div class="flex justify-end gap-2 items-center">
                <!-- Soporte Próximo (Vygotsky) -->
                <button id="hint-button" onclick="activateHint()" class="text-xs bg-slate-900 hover:bg-slate-850 text-cyan-400 hover:text-cyan-300 px-3 py-1.5 rounded-xl border border-cyan-800/40 transition-all flex items-center gap-1.5 active:scale-95">
                    <i class="fa-solid fa-wand-magic-sparkles animate-pulse"></i> Pista
                </button>
                <button onclick="goHome()" class="text-xs bg-slate-900 hover:bg-slate-850 text-slate-400 hover:text-white px-3 py-1.5 rounded-xl border border-slate-800 transition-all">
                    <i class="fa-solid fa-map-location-dot"></i> Universo
                </button>
            </div>
        </div>

        <!-- Panel de control interactivo -->
        <div class="w-full flex-grow grid grid-cols-1 lg:grid-cols-4 gap-4 items-stretch">
            <!-- Asistente de Inteligencia Emocional -->
            <div class="lg:col-span-1 bg-slate-950/45 backdrop-blur-md rounded-2xl border border-slate-900 p-4 flex flex-col items-center justify-between text-center relative overflow-hidden min-h-[180px]">
                <div class="bg-indigo-950/70 border border-indigo-500/15 p-3 rounded-xl text-xs text-slate-200 font-kid leading-relaxed relative w-full shadow-inner">
                    <span id="astrobot-bubble">¡Sistemas iniciados comandante! Selecciona la respuesta para calibrar.</span>
                    <div class="absolute right-1/2 translate-x-1/2 -bottom-2 w-3 h-3 bg-indigo-950 border-r border-b border-indigo-500/15 rotate-45"></div>
                </div>

                <div class="droid-float flex flex-col items-center mt-3">
                    <div class="bg-gradient-to-b from-indigo-500 to-purple-600 w-14 h-12 rounded-2xl border-2 border-slate-950 relative flex items-center justify-center">
                        <div class="w-10 h-8 bg-slate-950 rounded-xl flex items-center justify-around px-1.5 border border-indigo-400">
                            <div class="w-2.5 h-2.5 bg-cyan-400 rounded-full" id="bot-eye-l"></div>
                            <div class="w-2.5 h-2.5 bg-cyan-400 rounded-full" id="bot-eye-r"></div>
                        </div>
                    </div>
                    <div class="w-7 h-3 bg-slate-800 rounded-b-lg border-t border-indigo-300 relative">
                        <div class="absolute left-2.5 -bottom-1.5 w-2 h-2 bg-orange-500 rounded-full animate-ping"></div>
                    </div>
                </div>
            </div>

            <!-- Pantalla táctica central (Contenedores Dinámicos) -->
            <div id="tactical-board" class="lg:col-span-3 bg-slate-950/85 rounded-2xl border border-slate-800 flex flex-col justify-between p-5 relative overflow-hidden min-h-[350px]">
                <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(99,102,241,0.02)_0%,transparent_75%)] pointer-events-none"></div>

                <div class="text-center">
                    <h3 id="tactical-question" class="text-sm md:text-lg font-bold tracking-wide text-slate-100">Procesando desafío cognitivo...</h3>
                    <p id="tactical-hint" class="text-[9px] text-slate-500 uppercase tracking-widest mt-0.5">Andamiaje de Saberes</p>
                </div>

                <div class="flex-grow flex items-center justify-center py-4 min-h-[160px]">
                    <!-- MATEMÁTICAS CON APUYO SENSORIAL Y CONCRETO (Piaget) -->
                    <div id="game-math-container" class="hidden flex-col items-center gap-4 w-full">
                        <div class="flex items-center gap-4 font-kid text-2xl font-bold md:text-4xl text-white">
                            <span id="math-term-a" class="text-rose-400">0</span>
                            <span id="math-operator" class="text-slate-500">+</span>
                            <span id="math-term-b" class="text-rose-400">0</span>
                            <span class="text-slate-500">=</span>
                            <span class="text-yellow-400 border-b-2 border-dashed border-yellow-400 w-10 text-center">?</span>
                        </div>
                        
                        <!-- Representación dinámica de bloques para 1º y 2º (Operaciones concretas) -->
                        <div id="math-concrete-wrapper" class="w-full max-w-sm bg-slate-900/40 p-3 rounded-2xl border border-slate-800/80 flex flex-col gap-2">
